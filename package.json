{
  "name": "screeps-ok",
  "version": "0.2.0",
  "description": "Behavioral conformance suite for Screeps server implementations",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "tests",
    "bin",
    "scripts/run-suite.js",
    "scripts/preflight.js",
    "scripts/lib",
    "starter",
    "behaviors.md",
    "docs/adapter-spec.md",
    "docs/adapter-guide.md",
    "docs/test-authoring.md",
    "vitest.config.ts"
  ],
  "scripts": {
    "prepare": "node scripts/install-git-hooks.js",
    "prepublishOnly": "node scripts/generate-starter.js && node scripts/validate-package.js",
    "build:starter": "node scripts/generate-starter.js",
    "preflight": "node scripts/preflight.js",
    "setup": "node scripts/setup.js",
    "setup:xxscreeps": "node scripts/build-xxscreeps.js && node scripts/setup.js xxscreeps",
    "setup:vanilla": "node scripts/setup.js vanilla",
    "test": "node scripts/test.js",
    "posttest": "node scripts/generate-status.js && node scripts/generate-coverage.js",
    "test:watch": "vitest",
    "parity": "node scripts/parity-report.js",
    "coverage": "node scripts/generate-coverage.js",
    "status": "node scripts/generate-status.js",
    "status:refresh": "node scripts/parity-report.js && node scripts/generate-status.js",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "validate:capabilities": "node scripts/validate-capabilities.js",
    "validate:package": "node scripts/validate-package.js"
  },
  "bin": {
    "screeps-ok": "./bin/run.js"
  },
  "dependencies": {
    "@screeps/common": "^2.16.0"
  },
  "peerDependencies": {
    "vitest": "^3"
  },
  "devDependencies": {
    "@types/node": "^24",
    "screeps": "^4.3.0",
    "screeps-server-mockup": "^1.5.1",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "private": false,
  "license": "MIT"
}
