{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "xxscreeps/*": [
        "./node_modules/xxscreeps/dist/types/*",
        "./node_modules/xxscreeps/dist/*"
      ]
    }
  },
  "include": ["src/**/*", "adapters/**/*", "tests/**/*"]
}
