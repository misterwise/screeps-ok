#!/usr/bin/env bash
# Regenerate the status dashboard, README badges, and coverage report from
# the current repo state, then fail the commit if any of those files drifted
# from what was staged. Keeps published artifacts honest without running the
# multi-minute parity suite.

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Lint first — fast and catches type regressions before they ship.
if ! npx tsc --noEmit; then
	echo "pre-commit: lint failed — fix type errors and retry." >&2
	exit 1
fi

# Drift trap: xxscreeps engine-internals access must go through the helper
# module (adapters/xxscreeps/engine-internals.ts). See
# docs/xxscreeps-engine-internals-policy.md. Exception: `#flushObjects` in
# the inlined createSimulation fork.
drift=$(grep -nE "['\"]#[a-zA-Z_]" \
	adapters/xxscreeps/index.ts adapters/xxscreeps/snapshots.ts \
	| grep -v '#flushObjects' || true)
if [[ -n "$drift" ]]; then
	echo "pre-commit: xxscreeps engine-internals drift — direct \`#\` access outside engine-internals.ts:" >&2
	echo "$drift" >&2
	echo "See docs/xxscreeps-engine-internals-policy.md." >&2
	exit 1
fi

# Coverage derives from behaviors.md + tests/, so it can always regenerate.
node scripts/generate-coverage.js >/dev/null

# Status + README badges derive from reports/*.json — only run if at least
# one report is present (skips cleanly on a fresh clone).
if [[ -f reports/vanilla.json || -f reports/xxscreeps.json ]]; then
	node scripts/generate-status.js >/dev/null
fi

changed=()
for f in README.md docs/status.md docs/coverage.html; do
	if ! git diff --quiet -- "$f"; then
		changed+=("$f")
	fi
done

if (( ${#changed[@]} > 0 )); then
	echo "pre-commit: generated artifacts regenerated — stage and retry:" >&2
	for f in "${changed[@]}"; do
		echo "  git add $f" >&2
	done
	exit 1
fi
